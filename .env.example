# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# n8n
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# App — URL publik (OAuth, reset password). Harus cocok dengan Site URL & Redirect URLs di Supabase Auth.
# Reset password: daftarkan juga https://DOMAIN/auth/confirm — lihat komentar di src/lib/site-origin.ts (template email token_hash).
NEXT_PUBLIC_APP_URL=

# Mayar (checkout)
MAYAR_API_KEY=
MAYAR_WEBHOOK_SECRET=

# Cloudinary — upload input image (server); n8n hanya terima imageUrl
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder di Media Library (tanpa slash di awal/akhir)
CLOUDINARY_UPLOAD_FOLDER=rephot/uploads
